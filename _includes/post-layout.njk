<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — EcomDeals</title>
<meta name="description" content="{{ description }}">
<meta property="og:title" content="{{ title }} — EcomDeals">
<meta property="og:description" content="{{ description }}">
<meta property="og:type" content="article">
<meta property="og:url" content="https://ecomdeals.co.uk/blog/{{ title | slugify }}/">
<link rel="canonical" href="https://ecomdeals.co.uk/blog/{{ title | slugify }}/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet"></noscript>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-TCQ49Q7Z');</script>
<!-- End Google Tag Manager -->
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080C0A;
    --bg2: #0E1610;
    --bg3: #141F17;
    --card: #111811;
    --card-border: #1E2E21;
    --accent: #3DFF8F;
    --accent-dim: #1A7A42;
    --accent-muted: #0E3D22;
    --text: #F2F5F0;
    --text-muted: #7A9080;
    --text-dim: #4A5E50;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8,12,10,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--card-border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 4px;
    background: var(--bg2);
    border: 1px solid var(--card-border);
    border-radius: 8px;
    padding: 3px;
    align-items: center;
  }

  .nav-link {
    font-size: 13px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 6px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.18s;
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  .nav-link svg {
    width: 10px; height: 10px;
    opacity: 0.45;
    transition: transform 0.15s, opacity 0.15s;
    flex-shrink: 0;
  }

  .nav-link[aria-expanded="true"] svg { transform: rotate(180deg); opacity: 1; }
  .nav-link[aria-expanded="true"] { color: var(--text); }

  .nav-dropdown-wrap { position: relative; }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 240px;
    background: var(--bg3);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 5px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.55);
    z-index: 200;
  }

  .nav-link[aria-expanded="true"] + .nav-dropdown { display: block; }

  .dd-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .dd-item:hover { background: rgba(61,255,143,0.05); }

  .dd-icon {
    width: 32px; height: 32px;
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .dd-label strong {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }

  .dd-label span {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.45;
    font-weight: 300;
  }

  .dd-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 4px;
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
    margin-left: 5px;
    vertical-align: 1px;
  }

  /* ARTICLE */
  .article-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .article-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 20px;
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  .article-date, .article-readtime {
    font-size: 13px;
    color: var(--text-dim);
  }

  .meta-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--text-dim);
    display: inline-block;
  }

  h1.article-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(38px, 6vw, 58px);
    line-height: 0.97;
    letter-spacing: 1px;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .article-desc {
    font-size: 18px;
    color: var(--text-muted);
    font-weight: 300;
    line-height: 1.65;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--card-border);
  }

  .article-body h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 30px;
    letter-spacing: 1px;
    color: var(--text);
    margin: 2.5rem 0 1rem;
  }

  .article-body h3 {
    font-size: 18px;
    font-weight: 500;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .article-body p {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-weight: 300;
  }

  .article-body strong { color: var(--text); font-weight: 500; }

  .article-body a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-dim);
    transition: opacity 0.15s;
  }

  .article-body a:hover { opacity: 0.75; }

  .article-body ul, .article-body ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
    font-weight: 300;
  }

  .article-body li { margin-bottom: 0.5rem; }

  .article-body blockquote {
    border-left: 3px solid var(--accent);
    padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    margin: 2rem 0;
    background: var(--bg3);
    border-radius: 0 8px 8px 0;
    color: var(--text-muted);
    font-style: normal;
  }

  .article-body blockquote p {
    margin: 0;
    color: var(--text-muted);
  }

  .article-body blockquote strong {
    display: block;
    color: var(--accent);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    font-style: normal;
  }

  .article-body hr {
    border: none;
    border-top: 1px solid var(--card-border);
    margin: 2.5rem 0;
  }

  .article-body img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    margin: 2rem 0 0.5rem;
    border: 1px solid var(--card-border);
    display: block;
    filter: brightness(0.88) saturate(0.85);
  }

  .article-body img + em {
    display: block;
    text-align: center;
    font-size: 12px;
    color: var(--text-dim);
    font-style: normal;
    margin-bottom: 2rem;
    padding-top: 0.5rem;
    border-bottom: 1px solid var(--card-border);
    padding-bottom: 1rem;
  }

  .article-body .img-left {
    float: left;
    width: 45%;
    margin: 0.5rem 1.5rem 1rem 0;
  }

  .article-body .img-left img { margin: 0; }

  .article-body .img-right {
    float: right;
    width: 45%;
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .article-body .img-right img { margin: 0; }

  .article-body .clearfix::after {
    content: '';
    display: table;
    clear: both;
  }

  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 14px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--card-border);
  }

  .article-body thead tr {
    background: var(--accent-muted);
    border-bottom: 1px solid var(--accent-dim);
  }

  .article-body thead th {
    padding: 12px 16px;
    text-align: left;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .article-body tbody tr {
    border-bottom: 1px solid var(--card-border);
    transition: background 0.15s;
  }

  .article-body tbody tr:last-child { border-bottom: none; }
  .article-body tbody tr:nth-child(even) { background: var(--bg2); }
  .article-body tbody tr:hover { background: var(--bg3); }

  .article-body td {
    padding: 12px 16px;
    color: var(--text-muted);
    font-weight: 300;
    vertical-align: top;
  }

  .article-body td:first-child {
    color: var(--text);
    font-weight: 500;
  }

  .article-body code {
    background: var(--bg2);
    border: 1px solid var(--card-border);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 13px;
    color: var(--accent);
  }

  .hero-image-wrap {
    margin-bottom: 2.5rem;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--card-border);
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    filter: brightness(0.88) saturate(0.8);
  }

  .verdict-box {
    background: var(--bg3);
    border: 1px solid var(--accent-dim);
    border-radius: 10px;
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .verdict-box-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
    color: var(--accent);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .verdict-box ul { padding-left: 1.25rem; margin: 0; }

  .verdict-box li {
    color: var(--text-muted);
    font-weight: 300;
    margin-bottom: 0.5rem;
    font-size: 14px;
  }

  .verdict-box li strong { color: var(--text); }

  .article-cta {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--bg3);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .article-cta-text h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .article-cta-text p {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 300;
    margin: 0;
  }

  .article-cta-btn {
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 8px;
    padding: 11px 22px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.18s;
  }

  .article-cta-btn:hover { background: #5EFFAA; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--accent); }

  footer {
    border-top: 1px solid var(--card-border);
    padding: 2rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 13px;
  }

  footer a { color: var(--accent); text-decoration: none; }

  @media (max-width: 600px) {
    nav { padding: 0 1.25rem; }
    .nav-link { padding: 4px 8px; font-size: 11px; }
    .article-wrap { padding: 2rem 1.25rem 4rem; }
    .article-cta { flex-direction: column; }
  }
</style>
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TCQ49Q7Z"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<nav>
  <a href="/" class="nav-logo">Ecom<span>Deals</span></a>
  <div class="nav-links">
    <a href="/" class="nav-link">Deals</a>
    <a href="/blog/" class="nav-link active">Blog</a>

    <div class="nav-dropdown-wrap">
      <button class="nav-link" id="tools-btn" aria-haspopup="true" aria-expanded="false">
        Tools
        <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M1.5 3.5l3.5 3.5 3.5-3.5"/></svg>
      </button>
      <div class="nav-dropdown">
        <a href="/tools/profit-margin-calculator/" class="dd-item">
          <div class="dd-icon">%</div>
          <div class="dd-label">
            <strong>Profit Margin Calculator</strong>
            <span>Work out your margins, break-even and monthly projections</span>
          </div>
        </a>
      </div>
    </div>

    <div class="nav-dropdown-wrap">
      <button class="nav-link" id="services-btn" aria-haspopup="true" aria-expanded="false">
        Services
        <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M1.5 3.5l3.5 3.5 3.5-3.5"/></svg>
      </button>
      <div class="nav-dropdown">
        <a href="/launch-ready/" class="dd-item">
          <div class="dd-icon">✦</div>
          <div class="dd-label">
            <strong>Launch Ready <span class="dd-badge">£99</span></strong>
            <span>GA4 &amp; Search Console set up in 48 hours</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</nav>

<article class="article-wrap">

  <a href="/blog/" class="back-link">← Back to Blog</a>

  <div class="article-meta">
    <span class="article-tag">{{ category }}</span>
    <span class="article-date">{{ date | dateDisplay }}</span>
    <span class="meta-dot"></span>
    <span class="article-readtime">{{ content | readingTime }}</span>
  </div>

  <h1 class="article-title">{{ title }}</h1>
  <p class="article-desc">{{ description }}</p>

  {% if heroImage %}
  <div class="hero-image-wrap">
    <img src="{{ heroImage }}" alt="{{ heroImageAlt if heroImageAlt else title }}" class="hero-img" width="1440" height="810" loading="lazy">
  </div>
  {% endif %}

  <div class="article-body">
    {{ content | safe }}
  </div>

  <div class="article-cta">
    <div class="article-cta-text">
      <h3>Find Exclusive Deals on These Tools</h3>
      <p>Browse our curated affiliate codes for the best ecommerce platforms.</p>
    </div>
    <a href="/" class="article-cta-btn">Browse All Deals →</a>
  </div>

</article>

<footer>
  <p><strong>EcomDeals</strong> — <a href="mailto:hello@ecomdeals.co.uk">hello@ecomdeals.co.uk</a></p>
</footer>

<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }

  // Nav dropdowns
  const dropdownBtns = document.querySelectorAll('.nav-link[aria-haspopup="true"]');

  dropdownBtns.forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      const isOpen = this.getAttribute('aria-expanded') === 'true';
      dropdownBtns.forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
      this.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  document.addEventListener('click', function() {
    dropdownBtns.forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') dropdownBtns.forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
  });
</script>

</body>
</html>
