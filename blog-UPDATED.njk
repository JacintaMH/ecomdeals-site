<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080C0A;
    --bg2: #0E1610;
    --bg3: #141F17;
    --card: #111811;
    --card-border: #1E2E21;
    --accent: #3DFF8F;
    --accent-dim: #1A7A42;
    --accent-muted: #0E3D22;
    --text: #F2F5F0;
    --text-muted: #7A9080;
    --text-dim: #4A5E50;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── NAV ──────────────────────────────────────────── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8,12,10,0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--card-border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 4px;
    background: var(--bg2);
    border: 1px solid var(--card-border);
    border-radius: 8px;
    padding: 3px;
    align-items: center;
  }

  .nav-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-muted);
    transition: all 0.18s;
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link.active {
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  .nav-link:hover:not(.active) { color: var(--text); }

  .nav-link svg {
    width: 10px; height: 10px;
    opacity: 0.45;
    transition: transform 0.15s, opacity 0.15s;
    flex-shrink: 0;
  }

  .nav-link[aria-expanded="true"] svg { transform: rotate(180deg); opacity: 1; }
  .nav-link[aria-expanded="true"] { color: var(--text); }

  .nav-dropdown-wrap { position: relative; }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 240px;
    background: var(--bg3);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 5px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.55);
    z-index: 200;
  }

  .nav-link[aria-expanded="true"] + .nav-dropdown { display: block; }

  .dd-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .dd-item:hover { background: rgba(61,255,143,0.05); }

  .dd-icon {
    width: 32px; height: 32px;
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .dd-label strong {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }

  .dd-label span {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.45;
    font-weight: 300;
  }

  .dd-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 4px;
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
    margin-left: 5px;
    vertical-align: 1px;
  }

  /* ── PAGE STYLES (unchanged) ─────────────────────── */
  .hero {
    max-width: 860px;
    margin: 0 auto;
    padding: 70px 2rem 50px;
    text-align: center;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 500px; height: 250px;
    background: radial-gradient(ellipse at top, rgba(61,255,143,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 8vw, 78px);
    line-height: 0.95;
    letter-spacing: 1px;
    color: var(--text);
    margin-bottom: 1rem;
    min-height: 2em;
  }

  h1 em { font-style: normal; color: var(--accent); }

  .hero-sub {
    font-size: 16px;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .blog-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  .empty-blog { text-align: center; padding: 5rem 2rem; color: var(--text-muted); }
  .empty-blog h2 { font-family: 'Bebas Neue', sans-serif; font-size: 32px; color: var(--text); margin-bottom: 0.75rem; }
  .empty-blog p { font-weight: 300; font-size: 15px; }

  .cat-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.5rem; }

  .cat-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 400;
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--card-border);
    background: var(--bg2);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.18s;
  }

  .cat-btn:hover { border-color: var(--accent-dim); color: var(--text); }
  .cat-btn.active { background: var(--accent-muted); border-color: var(--accent-dim); color: var(--accent); }

  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    text-decoration: none;
    transition: background 0.18s;
  }

  .featured-post:hover { background: var(--bg3); }

  .featured-img {
    background: var(--bg2);
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .featured-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(8,12,10,0.35);
    pointer-events: none;
  }

  .featured-img-placeholder { font-family: 'Bebas Neue', sans-serif; font-size: 60px; color: var(--accent); opacity: 0.15; letter-spacing: 2px; }

  .featured-body { padding: 2rem; display: flex; flex-direction: column; justify-content: center; gap: 12px; }

  .post-tag {
    font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); background: var(--accent-muted); border: 1px solid var(--accent-dim);
    padding: 3px 10px; border-radius: 20px; width: fit-content;
  }

  .post-title { font-family: 'Bebas Neue', sans-serif; font-size: 28px; line-height: 1; letter-spacing: 0.5px; color: var(--text); }
  .post-excerpt { font-size: 13px; color: var(--text-muted); font-weight: 300; line-height: 1.65; }
  .post-meta { font-size: 11px; color: var(--text-dim); display: flex; gap: 8px; align-items: center; }
  .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-dim); }
  .read-btn { display: inline-block; font-size: 13px; font-weight: 500; color: var(--accent); margin-top: 4px; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .post-card { background: var(--card); display: flex; flex-direction: column; text-decoration: none; transition: background 0.18s; }
  .post-card:hover { background: var(--bg3); }

  .post-card-img { background: var(--bg2); height: 140px; display: flex; align-items: center; justify-content: center; background-size: cover; background-position: center; }
  .post-card-img-placeholder { font-family: 'Bebas Neue', sans-serif; font-size: 40px; color: var(--accent); opacity: 0.12; }

  .post-card-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .post-card-title { font-family: 'Bebas Neue', sans-serif; font-size: 20px; line-height: 1.05; color: var(--text); }
  .post-card-excerpt { font-size: 12px; color: var(--text-muted); font-weight: 300; line-height: 1.6; flex: 1; }

  .post-card-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 10px; border-top: 1px solid var(--card-border);
    margin-top: 4px; font-size: 11px; color: var(--text-dim);
  }

  .post-arrow { color: var(--accent); font-size: 13px; }

  footer { border-top: 1px solid var(--card-border); padding: 2rem; text-align: center; color: var(--text-dim); font-size: 13px; }
  footer a { color: var(--accent); text-decoration: none; }

  .footer-links { display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; margin-top: 0.75rem; }
  .footer-links a { font-size: 12px; color: var(--text-dim); text-decoration: none; transition: color 0.15s; }
  .footer-links a:hover { color: var(--accent); }

  @media (max-width: 700px) {
    nav { padding: 0 1rem; }
    .nav-link { padding: 5px 10px; font-size: 12px; }
    .featured-post { grid-template-columns: 1fr; }
    .featured-img { min-height: 160px; }
    .posts-grid { grid-template-columns: 1fr; }
    .hero, .blog-wrap { padding-left: 1.25rem; padding-right: 1.25rem; }
  }

  @media (max-width: 420px) {
    .nav-links { gap: 2px; padding: 2px; }
    .nav-link { padding: 4px 7px; font-size: 11px; }
  }
</style>
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TCQ49Q7Z"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<nav>
  <a href="/" class="nav-logo">Ecom<span>Deals</span></a>
  <div class="nav-links">
    <a href="/" class="nav-link">Deals</a>
    <a href="/blog/" class="nav-link active" aria-current="page">Blog</a>

    <div class="nav-dropdown-wrap">
      <button class="nav-link" id="tools-btn" aria-haspopup="true" aria-expanded="false">
        Tools
        <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M1.5 3.5l3.5 3.5 3.5-3.5"/></svg>
      </button>
      <div class="nav-dropdown">
        <a href="/tools/profit-margin-calculator/" class="dd-item">
          <div class="dd-icon">%</div>
          <div class="dd-label">
            <strong>Profit Margin Calculator</strong>
            <span>Work out your margins, break-even and monthly projections</span>
          </div>
        </a>
      </div>
    </div>

    <div class="nav-dropdown-wrap">
      <button class="nav-link" id="services-btn" aria-haspopup="true" aria-expanded="false">
        Services
        <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M1.5 3.5l3.5 3.5 3.5-3.5"/></svg>
      </button>
      <div class="nav-dropdown">
        <a href="/launch-ready/" class="dd-item">
          <div class="dd-icon">✦</div>
          <div class="dd-label">
            <strong>Launch Ready <span class="dd-badge">£99</span></strong>
            <span>GA4 &amp; Search Console set up in 48 hours</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</nav>

<section class="hero">
  <h1>Grow Smarter.<br><em>Sell More.</em></h1>
  <p class="hero-sub">Platform guides, tool comparisons, and conversion tips — written for ecommerce founders.</p>
</section>

<div class="blog-wrap">

  {% if collections.posts and collections.posts.length > 0 %}

  <div class="cat-filters" id="catFilters" role="group" aria-label="Filter posts by category">
    <button class="cat-btn active" data-cat="all">All</button>
    <button class="cat-btn" data-cat="Platform Guide">Platform Guide</button>
    <button class="cat-btn" data-cat="Getting Started">Getting Started</button>
    <button class="cat-btn" data-cat="Store Optimisation">Store Optimisation</button>
    <button class="cat-btn" data-cat="Email & SMS">Email &amp; SMS</button>
    <button class="cat-btn" data-cat="Analytics & Reporting">Analytics &amp; Reporting</button>
    <button class="cat-btn" data-cat="Tools & Apps">Tools &amp; Apps</button>
    <button class="cat-btn" data-cat="Payments & Checkout">Payments &amp; Checkout</button>
    <button class="cat-btn" data-cat="Shipping & Fulfilment">Shipping &amp; Fulfilment</button>
    <button class="cat-btn" data-cat="SEO & Marketing">SEO &amp; Marketing</button>
    <button class="cat-btn" data-cat="Social Commerce">Social Commerce</button>
  </div>

  {% set featuredPost = collections.posts | reverse | first %}

  <a href="{{ featuredPost.url }}" class="featured-post" data-category="{{ featuredPost.data.category }}">
    <div class="featured-img" {% if featuredPost.data.heroImage %}style="background-image: url('{{ featuredPost.data.heroImage }}'); background-size: cover; background-position: center;"{% endif %}>
      {% if not featuredPost.data.heroImage %}
      <span class="featured-img-placeholder">{{ featuredPost.data.category | upper }}</span>
      {% endif %}
    </div>
    <div class="featured-body">
      <span class="post-tag">{{ featuredPost.data.category }}</span>
      <div class="post-title">{{ featuredPost.data.title }}</div>
      <p class="post-excerpt">{{ featuredPost.data.description }}</p>
      <div class="post-meta">
        <span>{{ featuredPost.date | dateDisplay }}</span>
        <span class="meta-dot"></span>
        <span>{{ featuredPost.content | readingTime }}</span>
      </div>
      <span class="read-btn">Read Article →</span>
    </div>
  </a>

  {% set remainingPosts = collections.posts | reverse %}
  {% if collections.posts.length > 1 %}
  <div class="posts-grid" id="postsGrid">
    {% for post in remainingPosts %}
      {% if not loop.first %}
      <a href="{{ post.url }}" class="post-card" data-category="{{ post.data.category }}">
        <div class="post-card-img" {% if post.data.heroImage %}style="background-image: url('{{ post.data.heroImage }}'); background-size: cover; background-position: center;"{% endif %}>
          {% if not post.data.heroImage %}
          <span class="post-card-img-placeholder">{{ post.data.category | upper }}</span>
          {% endif %}
        </div>
        <div class="post-card-body">
          <span class="post-tag">{{ post.data.category }}</span>
          <div class="post-card-title">{{ post.data.title }}</div>
          <p class="post-card-excerpt">{{ post.data.description }}</p>
          <div class="post-card-footer">
            <span>{{ post.date | dateDisplay }} · {{ post.content | readingTime }}</span>
            <span class="post-arrow">→</span>
          </div>
        </div>
      </a>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  {% else %}

  <div class="empty-blog">
    <h2>Posts Coming Soon</h2>
    <p>We're working on guides, comparisons, and tips for ecommerce founders.<br>Check back shortly or <a href="/" style="color:var(--accent);">browse our deals</a> in the meantime.</p>
  </div>

  {% endif %}

</div>

<footer>
  <p><strong>EcomDeals</strong> — <a href="mailto:hello@ecomdeals.co.uk">hello@ecomdeals.co.uk</a></p>
  <div class="footer-links">
    <a href="/affiliate-disclosure/">Affiliate Disclosure</a>
    <a href="/privacy-policy/">Privacy Policy</a>
    <a href="/terms/">Terms &amp; Conditions</a>
    <a href="/cookie-policy/">Cookie Policy</a>
  </div>
</footer>

<script>
  document.querySelectorAll('.cat-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.cat-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var cat = btn.dataset.cat;
      var featured = document.querySelector('.featured-post');
      if (featured) { featured.style.display = (cat === 'all' || featured.dataset.category === cat) ? '' : 'none'; }
      document.querySelectorAll('.post-card').forEach(function(card) {
        card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
      });
    });
  });

  // Nav dropdowns
  const dropdownBtns = document.querySelectorAll('.nav-link[aria-haspopup="true"]');
  dropdownBtns.forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      const isOpen = this.getAttribute('aria-expanded') === 'true';
      dropdownBtns.forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
      this.setAttribute('aria-expanded', String(!isOpen));
    });
  });
  document.addEventListener('click', function() {
    dropdownBtns.forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') dropdownBtns.forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
  });

  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) { window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; }); }
    });
  }
</script>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>
</body>
</html>
