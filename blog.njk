---
permalink: /blog/index.html
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blog — EcomDeals</title>
<meta name="description" content="Ecommerce guides, platform comparisons, and tips to grow your online store. Written for founders by founders.">
<link rel="canonical" href="https://ecomdeals.co.uk/blog/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080C0A;
    --bg2: #0E1610;
    --bg3: #141F17;
    --card: #111811;
    --card-border: #1E2E21;
    --accent: #3DFF8F;
    --accent-dim: #1A7A42;
    --accent-muted: #0E3D22;
    --text: #F2F5F0;
    --text-muted: #7A9080;
    --text-dim: #4A5E50;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8,12,10,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--card-border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover, .nav-links a.active { color: var(--accent); }

  /* HERO */
  .hero {
    max-width: 860px;
    margin: 0 auto;
    padding: 70px 2rem 50px;
    text-align: center;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 500px; height: 250px;
    background: radial-gradient(ellipse at top, rgba(61,255,143,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
    padding: 5px 14px;
    border: 1px solid var(--accent-dim);
    border-radius: 20px;
    background: var(--accent-muted);
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 8vw, 78px);
    line-height: 0.95;
    letter-spacing: 1px;
    color: var(--text);
    margin-bottom: 1rem;
  }

  h1 em { font-style: normal; color: var(--accent); }

  .hero-sub {
    font-size: 16px;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* GRID */
  .blog-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  /* Empty state */
  .empty-blog {
    text-align: center;
    padding: 5rem 2rem;
    color: var(--text-muted);
  }

  .empty-blog h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .empty-blog p { font-weight: 300; font-size: 15px; }

  .nav-tabs {
    display: flex;
    gap: 4px;
    background: var(--bg2);
    border: 1px solid var(--card-border);
    border-radius: 8px;
    padding: 3px;
  }

  .nav-tab {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-muted);
    transition: all 0.18s;
  }

  .nav-tab.active {
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  .nav-tab:hover:not(.active) { color: var(--text); }

  .nav-badge {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  /* Category filters */
  .cat-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .cat-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 400;
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--card-border);
    background: var(--bg2);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.18s;
  }

  .cat-btn:hover { border-color: var(--accent-dim); color: var(--text); }
  .cat-btn.active { background: var(--accent-muted); border-color: var(--accent-dim); color: var(--accent); }


  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    text-decoration: none;
    transition: background 0.18s;
  }

  .featured-post:hover { background: var(--bg3); }

  .featured-img {
    background: var(--bg2);
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-img-placeholder {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 60px;
    color: var(--accent);
    opacity: 0.15;
    letter-spacing: 2px;
  }

  .featured-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
  }

  .post-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    padding: 3px 10px;
    border-radius: 20px;
    width: fit-content;
  }

  .post-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    line-height: 1;
    letter-spacing: 0.5px;
    color: var(--text);
  }

  .post-excerpt {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 300;
    line-height: 1.65;
  }

  .post-meta {
    font-size: 11px;
    color: var(--text-dim);
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-dim); }

  .read-btn {
    display: inline-block;
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    margin-top: 4px;
  }

  /* Post grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .post-card {
    background: var(--card);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: background 0.18s;
  }

  .post-card:hover { background: var(--bg3); }

  .post-card-img {
    background: var(--bg2);
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-card-img-placeholder {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 40px;
    color: var(--accent);
    opacity: 0.12;
  }

  .post-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .post-card-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    line-height: 1.05;
    color: var(--text);
  }

  .post-card-excerpt {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 300;
    line-height: 1.6;
    flex: 1;
  }

  .post-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 10px;
    border-top: 1px solid var(--card-border);
    margin-top: 4px;
    font-size: 11px;
    color: var(--text-dim);
  }

  .post-arrow { color: var(--accent); font-size: 13px; }

  footer {
    border-top: 1px solid var(--card-border);
    padding: 2rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 13px;
  }

  footer a { color: var(--accent); text-decoration: none; }

  @media (max-width: 700px) {
    .featured-post { grid-template-columns: 1fr; }
    .featured-img { min-height: 160px; }
    .posts-grid { grid-template-columns: 1fr; }
    nav { padding: 0 1.25rem; }
    .hero, .blog-wrap { padding-left: 1.25rem; padding-right: 1.25rem; }
  }
</style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">Ecom<span>Deals</span></a>
  <div class="nav-tabs">
    <a href="/" class="nav-tab">Deals</a>
    <a href="/blog/" class="nav-tab active">Blog</a>
  </div>
  <div class="nav-badge">✦ Ecom Guides</div>
</nav>

<section class="hero">
  <div class="hero-eyebrow">✦ Ecommerce Guides</div>
  <h1>Grow Smarter.<br><em>Sell More.</em></h1>
  <p class="hero-sub">Platform guides, tool comparisons, and conversion tips — written for ecommerce founders.</p>
</section>

<div class="blog-wrap">

  {% if collections.posts and collections.posts.length > 0 %}

  <!-- Category filters -->
  <div class="cat-filters" id="catFilters">
    <button class="cat-btn active" data-cat="all">All</button>
    <button class="cat-btn" data-cat="Platform Guide">Platform Guide</button>
    <button class="cat-btn" data-cat="Roundup">Roundup</button>
    <button class="cat-btn" data-cat="Beginner Guide">Beginner Guide</button>
    <button class="cat-btn" data-cat="Conversion">Conversion</button>
    <button class="cat-btn" data-cat="Email &amp; SMS">Email &amp; SMS</button>
    <button class="cat-btn" data-cat="Analytics">Analytics</button>
    <button class="cat-btn" data-cat="Case Study">Case Study</button>
  </div>

    {% set featuredPost = collections.posts[0] %}

    <!-- Featured post -->
    <a href="{{ featuredPost.url }}" class="featured-post" data-category="{{ featuredPost.data.category }}">
      <div class="featured-img">
        <span class="featured-img-placeholder">{{ featuredPost.data.category | upper }}</span>
      </div>
      <div class="featured-body">
        <span class="post-tag">{{ featuredPost.data.category }}</span>
        <div class="post-title">{{ featuredPost.data.title }}</div>
        <p class="post-excerpt">{{ featuredPost.data.description }}</p>
        <div class="post-meta">
          <span>{{ featuredPost.date | dateDisplay }}</span>
          <span class="meta-dot"></span>
          <span>{{ featuredPost.content | readingTime }}</span>
        </div>
        <span class="read-btn">Read Article →</span>
      </div>
    </a>

    {% if collections.posts.length > 1 %}
    <div class="posts-grid" id="postsGrid">
      {% for post in collections.posts %}
        {% if not loop.first %}
        <a href="{{ post.url }}" class="post-card" data-category="{{ post.data.category }}">
          <div class="post-card-img">
            <span class="post-card-img-placeholder">{{ post.data.category | upper }}</span>
          </div>
          <div class="post-card-body">
            <span class="post-tag">{{ post.data.category }}</span>
            <div class="post-card-title">{{ post.data.title }}</div>
            <p class="post-card-excerpt">{{ post.data.description }}</p>
            <div class="post-card-footer">
              <span>{{ post.date | dateDisplay }} · {{ post.content | readingTime }}</span>
              <span class="post-arrow">→</span>
            </div>
          </div>
        </a>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

  {% else %}

    <div class="empty-blog">
      <h2>Posts Coming Soon</h2>
      <p>We're working on guides, comparisons, and tips for ecommerce founders.<br>Check back shortly or <a href="/" style="color:var(--accent);">browse our deals</a> in the meantime.</p>
    </div>

  {% endif %}

</div>

<footer>
  <p><strong>EcomDeals</strong> — <a href="mailto:hello@ecomdeals.co.uk">hello@ecomdeals.co.uk</a></p>
</footer>

<script>
  // Category filtering
  document.querySelectorAll('.cat-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.cat-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var cat = btn.dataset.cat;
      // Filter featured post
      var featured = document.querySelector('.featured-post');
      if (featured) {
        featured.style.display = (cat === 'all' || featured.dataset.category === cat) ? '' : 'none';
      }
      // Filter grid cards
      document.querySelectorAll('.post-card').forEach(function(card) {
        card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
      });
    });
  });

  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>

</body>
</html>
