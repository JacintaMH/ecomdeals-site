<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #080C0A;
    --bg2:          #0E1610;
    --bg3:          #141F17;
    --card:         #111811;
    --card-border:  #1E2E21;
    --accent:       #3DFF8F;
    --accent-dim:   #1A7A42;
    --accent-muted: #0E3D22;
    --text:         #F2F5F0;
    --text-muted:   #7A9080;
    --text-dim:     #4A5E50;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  /* ── NAV ─────────────────────────────────────────── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8,12,10,0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--card-border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 4px;
    background: var(--bg2);
    border: 1px solid var(--card-border);
    border-radius: 8px;
    padding: 3px;
    align-items: center;
  }

  .nav-link {
    font-size: 13px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 6px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.18s;
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link:hover { color: var(--text); }

  .nav-link.active {
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  .nav-link svg {
    width: 10px; height: 10px;
    opacity: 0.45;
    transition: transform 0.15s, opacity 0.15s;
    flex-shrink: 0;
  }

  .nav-link[aria-expanded="true"] svg { transform: rotate(180deg); opacity: 1; }
  .nav-link[aria-expanded="true"] { color: var(--text); }

  /* Dropdown */
  .nav-dropdown-wrap { position: relative; }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 240px;
    background: var(--bg3);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 5px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.55);
    z-index: 200;
  }

  .nav-link[aria-expanded="true"] + .nav-dropdown { display: block; }

  .dd-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .dd-item:hover { background: rgba(61,255,143,0.05); }

  .dd-icon {
    width: 32px; height: 32px;
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .dd-label strong {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }

  .dd-label span {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.45;
    font-weight: 300;
  }

  .dd-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 4px;
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
    margin-left: 5px;
    vertical-align: 1px;
  }

  /* ── HERO ─────────────────────────────────────────── */
  .hero {
    padding: 88px 2rem 70px;
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse at top, rgba(61,255,143,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    padding: 5px 14px;
    border: 1px solid var(--accent-dim);
    border-radius: 20px;
    background: var(--accent-muted);
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 9vw, 86px);
    line-height: 0.95;
    letter-spacing: 1px;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  h1 em { font-style: normal; color: var(--accent); }

  .hero-sub {
    font-size: 17px;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 500px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: var(--bg);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 12px 26px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: background 0.18s, transform 0.15s;
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .hero-cta:hover { background: #5EFFAA; transform: translateY(-1px); }

  .hero-note {
    margin-top: 0.85rem;
    font-size: 12px;
    color: var(--text-dim);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--card-border);
  }

  .stat { text-align: center; }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 34px;
    letter-spacing: 1px;
    color: var(--accent);
    display: block;
  }

  .stat-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ── SECTIONS ─────────────────────────────────────── */
  .section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 72px 2rem;
  }

  .section-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(38px, 5vw, 58px);
    line-height: 0.95;
    letter-spacing: 1px;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  h2 em { font-style: normal; color: var(--accent); }

  .section-sub {
    font-size: 15px;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  hr { border: none; border-top: 1px solid var(--card-border); max-width: 1100px; margin: 0 auto; }

  /* ── PROBLEM GRID ─────────────────────────────────── */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .problem-card {
    background: var(--card);
    padding: 1.5rem;
    transition: background 0.18s;
  }

  .problem-card:hover { background: var(--bg3); }

  .p-icon { font-size: 22px; margin-bottom: 1rem; }

  .problem-card h3 { font-size: 14px; font-weight: 500; margin-bottom: 6px; }
  .problem-card p  { font-size: 13px; color: var(--text-muted); font-weight: 300; line-height: 1.6; }

  /* ── INCLUDES ─────────────────────────────────────── */
  .alt-section {
    background: var(--bg3);
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
  }

  .includes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .inc-item {
    background: var(--card);
    padding: 1.4rem 1.5rem;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    transition: background 0.18s;
  }

  .inc-item:hover { background: var(--bg3); }

  .inc-check {
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
    font-size: 11px;
    color: var(--accent);
  }

  .inc-item h3 { font-size: 14px; font-weight: 500; margin-bottom: 4px; }
  .inc-item p  { font-size: 13px; color: var(--text-muted); font-weight: 300; line-height: 1.6; }

  /* ── STEPS ────────────────────────────────────────── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .step {
    background: var(--card);
    padding: 1.4rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition: background 0.18s;
  }

  .step:hover { background: var(--bg3); }

  .step-num {
    width: 28px; height: 28px;
    border-radius: 50%;
    border: 1px solid var(--card-border);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px;
    color: var(--text-dim);
    flex-shrink: 0;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 1px;
  }

  .step h3 { font-size: 14px; font-weight: 500; margin-bottom: 3px; }
  .step p  { font-size: 13px; color: var(--text-muted); font-weight: 300; }

  .step-pill {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── TESTIMONIALS ─────────────────────────────────── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .testimonial-card {
    background: var(--card);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: background 0.18s;
  }

  .testimonial-card:hover { background: var(--bg3); }
  .testimonial-stars { color: var(--accent); font-size: 13px; letter-spacing: 2px; }

  .testimonial-quote {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 300;
    line-height: 1.75;
    flex: 1;
  }

  .testimonial-quote strong { color: var(--text); font-weight: 500; }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 1rem;
    border-top: 1px solid var(--card-border);
  }

  .testimonial-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 500;
    color: var(--accent);
    flex-shrink: 0;
  }

  .testimonial-name { font-size: 13px; font-weight: 500; color: var(--text); display: block; }
  .testimonial-meta { font-size: 12px; color: var(--text-dim); }

  /* ── FAQ ──────────────────────────────────────────── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .faq-item { background: var(--card); }

  .faq-question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    transition: background 0.15s, color 0.15s;
  }

  .faq-question:hover { background: var(--bg3); }
  .faq-question svg { width: 14px; height: 14px; flex-shrink: 0; color: var(--text-dim); transition: transform 0.2s, color 0.15s; }
  .faq-item.open .faq-question { color: var(--accent); }
  .faq-item.open .faq-question svg { transform: rotate(45deg); color: var(--accent); }

  .faq-answer {
    display: none;
    padding: 1rem 1.5rem 1.25rem;
    font-size: 14px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.75;
    border-top: 1px solid var(--card-border);
  }

  .faq-item.open .faq-answer { display: block; }
  .faq-answer a { color: var(--accent); }

  /* ── PRICING ──────────────────────────────────────── */
  .urgency-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 13px;
    color: var(--text-muted);
    max-width: 460px;
    margin: 0 auto 3rem;
  }

  .urgency-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
  .urgency-banner strong { color: var(--text); }

  .pricing-card {
    max-width: 460px;
    margin: 0 auto;
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    overflow: hidden;
  }

  .pricing-head {
    background: var(--bg3);
    padding: 2rem 2rem 1.75rem;
    border-bottom: 1px solid var(--card-border);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .pricing-head::before {
    content: '';
    position: absolute;
    top: -40px; left: 50%;
    transform: translateX(-50%);
    width: 260px; height: 180px;
    background: radial-gradient(ellipse at top, rgba(61,255,143,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .pricing-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .price-display { font-family: 'Bebas Neue', sans-serif; line-height: 1; margin-bottom: 0.4rem; }
  .price-display .sym { font-size: 28px; vertical-align: top; line-height: 1.6; color: var(--text-muted); }
  .price-display .num { font-size: 80px; letter-spacing: 2px; }
  .price-sub { font-size: 12px; color: var(--text-dim); }

  .pricing-body { padding: 1.75rem 2rem; }

  .feat-list { list-style: none; margin-bottom: 1.5rem; }

  .feat-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 300;
    padding: 8px 0;
    border-bottom: 1px solid var(--card-border);
  }

  .feat-list li:last-child { border-bottom: none; }

  .feat-list li .check {
    width: 16px; height: 16px;
    background: var(--accent-muted);
    border: 1px solid var(--accent-dim);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 9px;
    color: var(--accent);
  }

  .btn-buy {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--accent);
    color: var(--bg);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 13px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: background 0.18s;
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .btn-buy:hover { background: #5EFFAA; }

  .pricing-note { text-align: center; margin-top: 0.85rem; font-size: 12px; color: var(--text-dim); }
  .pricing-note a { color: var(--accent); }

  /* ── FINAL CTA ────────────────────────────────────── */
  .final-cta {
    max-width: 700px;
    margin: 0 auto;
    padding: 60px 2rem 90px;
    text-align: center;
    position: relative;
  }

  .final-cta::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 500px; height: 200px;
    background: radial-gradient(ellipse at top, rgba(61,255,143,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-cta h2 { margin-bottom: 0.75rem; }
  .final-cta p { font-size: 15px; color: var(--text-muted); font-weight: 300; margin-bottom: 2rem; }

  /* ── FOOTER ───────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--card-border);
    padding: 2rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 13px;
  }

  footer strong { color: var(--text-muted); }
  footer a { color: var(--accent); text-decoration: none; }

  .footer-links { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; margin-top: 0.75rem; }
  .footer-links a { color: var(--text-dim); transition: color 0.15s; font-size: 12px; }
  .footer-links a:hover { color: var(--text-muted); }

  /* ── MOBILE ───────────────────────────────────────── */
  @media (max-width: 700px) {
    nav { padding: 0 1rem; }
    .nav-logo { font-size: 19px; }
    .nav-link { padding: 5px 10px; font-size: 12px; }
    .hero { padding: 52px 1.25rem 44px; }
    h1 { font-size: 50px; }
    .hero-sub { font-size: 15px; }
    .hero-stats { gap: 1.5rem; }
    .stat-num { font-size: 28px; }
    .section { padding: 48px 1.25rem; }
    h2 { font-size: 38px; }
    .problem-grid { grid-template-columns: 1fr; }
    .includes-grid { grid-template-columns: 1fr; }
    .step-pill { display: none; }
    .pricing-card { margin: 0; }
    .price-display .num { font-size: 64px; }
    .pricing-head { padding: 1.5rem 1.5rem 1.25rem; }
    .pricing-body { padding: 1.25rem 1.5rem; }
    footer { padding: 2rem 1.25rem; }
    .footer-links { gap: 1rem; }
    .final-cta { padding: 48px 1.25rem 72px; }
  }

  @media (max-width: 420px) {
    .nav-links { gap: 2px; padding: 2px; }
